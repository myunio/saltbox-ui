{
  "name": "@myunio/saltbox-ui",
  "version": "0.1.0",
  "description": "Saltbox UI — Composable Vue component library inspired by Quasar, built with Tailwind CSS",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/myunio/saltbox-ui.git"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/saltbox.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "vite build && vue-tsc --declaration --emitDeclarationOnly --project tsconfig.build.json",
    "dev": "vite build --watch",
    "check": "oxlint src && vue-tsc --noEmit && oxfmt --check src",
    "lint": "oxlint src",
    "lint:fix": "oxlint --fix src",
    "fmt": "oxfmt --write src",
    "fmt:check": "oxfmt --check src",
    "typecheck": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "@nuxt/ui": ">=4.0.0",
    "tailwindcss": ">=4.0.0",
    "vue": ">=3.5.0"
  },
  "devDependencies": {
    "@nuxt/ui": "^4.6.1",
    "oxfmt": "^0.7.0",
    "oxlint": "^0.18.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.8.3",
    "vite": "^8.0.8",
    "vue": "^3.5.32",
    "vue-tsc": "^2.2.10",
    "@vitejs/plugin-vue": "^6.0.0"
  }
}
